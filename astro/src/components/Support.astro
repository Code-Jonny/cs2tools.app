---

---

<section id="support" class="section-pad support-section">
  <div class="container">
    <div class="section-head reveal">
      <span class="section-eyebrow">// Support</span>
      <h2 class="section-title">Like the app? No pressure.</h2>
      <p class="section-sub">
        CS2 Tools is free, open-source, and always will be. If it saved you time
        or improved your sessions and you feel like giving something back — this
        is how.
      </p>
    </div>

    <div class="support-grid">
      <div class="support-card reveal">
        <div class="support-card-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28"
            ><path
              d="M20 4H4c-1.103 0-2 .897-2 2v12c0 1.103.897 2 2 2h16c1.103 0 2-.897 2-2V6c0-1.103-.897-2-2-2zm0 2v.511l-8 4.8-8-4.8V6h16zM4 18V9.044l7.386 4.432a1 1 0 0 0 1.228 0L20 9.044 20.002 18H4z"
            ></path></svg
          >
        </div>
        <div class="support-card-body">
          <h3>Send a tip via PayPal</h3>
          <p>
            A one-time donation, whatever feels right — even a coffee's worth
            keeps the motivation going.
          </p>
          <a
            href="https://www.paypal.com/donate/?hosted_button_id=ZY4J7VV2AV2HC"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary support-btn"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"
              ><path
                d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106zm14.146-14.42a3.35 3.35 0 0 0-.607-.541c-.013.076-.026.175-.041.254-.93 4.778-4.005 7.201-9.138 7.201h-2.19a.563.563 0 0 0-.556.479l-1.187 7.527h-.506l-.24 1.516a.56.56 0 0 0 .554.647h3.882c.46 0 .85-.334.922-.788.06-.26.76-4.852.816-5.09a.932.932 0 0 1 .923-.788h.58c3.76 0 6.705-1.528 7.565-5.946.36-1.847.174-3.388-.777-4.471z"
              ></path></svg
            >
            Donate via PayPal
          </a>
        </div>
      </div>

      <div class="support-card reveal">
        <div class="support-card-icon support-card-icon--steam">
          <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28"
            ><path
              d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.187.008l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.718L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.497 1.009 2.455-.397.957-1.497 1.409-2.455 1.012zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.662 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.252 0-2.265-1.014-2.265-2.265z"
            ></path></svg
          >
        </div>
        <div class="support-card-body">
          <h3>Send a CS2 skin via Steam</h3>
          <p>
            Got a spare skin collecting dust in your inventory? Send it over —
            any skin is appreciated, no matter the value.
          </p>
          <a
            href="https://steamcommunity.com/tradeoffer/new/?partner=472413666&token=r8OLzAvB"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-ghost support-btn"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"
              ><path
                d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.187.008l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.718L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0z"
              ></path></svg
            >
            Send a Trade Offer
          </a>
        </div>
      </div>
    </div>

    <p class="support-note reveal">
      Only do this if you genuinely want to and can easily afford it. The app
      costs nothing and that will never change.
    </p>
  </div>
</section>

<style>
  .support-section {
    border-top: 1px solid var(--border);
  }

  .support-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 860px;
    margin: 0 auto;
  }

  @media (max-width: 640px) {
    .support-grid {
      grid-template-columns: 1fr;
    }
  }

  .support-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition:
      border-color 0.2s,
      transform 0.2s;
  }

  .support-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }

  .support-card-icon {
    width: 52px;
    height: 52px;
    background: var(--yellow-soft);
    border: 1px solid rgba(251, 201, 30, 0.2);
    border-radius: 12px;
    display: grid;
    place-items: center;
    color: var(--yellow);
    flex-shrink: 0;
  }

  .support-card-icon--steam {
    background: rgba(59, 156, 255, 0.1);
    border-color: rgba(59, 156, 255, 0.2);
    color: var(--blue);
  }

  .support-card-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .support-card-body h3 {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .support-card-body p {
    font-size: 14px;
    color: var(--text-dim);
    line-height: 1.6;
    flex: 1;
  }

  .support-btn {
    align-self: flex-start;
    margin-top: 6px;
  }

  .support-note {
    text-align: center;
    font-size: 13px;
    color: var(--text-mute);
    margin-top: 36px;
    font-style: italic;
  }
</style>
